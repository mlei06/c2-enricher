# Sensor env template. Copy to stingar-hp.env and fill the marked values:
#   cp stingar-hp.env.example stingar-hp.env
# (stingar-hp.env is gitignored — it holds the shared FLUENTD_KEY secret.)

# --- Central STINGAR server (where the local fluentbit forwards to) ---------
FLUENTD_HOST=vcm-51366.vm.duke.edu
FLUENTD_PORT=24224
# MUST equal the central c2-deploy stack's FLUENTD_KEY, or events are rejected:
#   ssh <user>@<central> "grep '^FLUENTD_KEY=' ~/stingar/c2-deploy/stingar.env"
FLUENTD_KEY=CHANGEME
FLUENTD_APP=stingar

# --- Local fluentbit sidecar (cowrie -> fluentbit) --------------------------
FLUENTBIT_HOST=fluentbit
FLUENTBIT_PORT=24284
FLUENTBIT_APP=stingar
FLUENTBIT_HOSTNAME=flb.local

# --- This honeypot's identity (one per host) --------------------------------
# HONEYPOT_IDENT: any stable unique id, e.g. `cat /proc/sys/kernel/random/uuid`
HONEYPOT_IDENT=CHANGEME
# HONEYPOT_IP: the host's PUBLIC ip (dig +short <domain>), NOT the private NAT ip
HONEYPOT_IP=CHANGEME
HONEYPOT_HOST=CHANGEME
HONEYPOT_ASN=
TAGS=network:dmz

HONEYPOT_HEALTHCHECK_INTERVAL=60m
HONEYPOT_HEALTHCHECK_TIMEOUT=60s
