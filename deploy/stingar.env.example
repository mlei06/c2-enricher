# Central STINGAR server environment template.
#   cp stingar.env.example stingar.env  &&  $EDITOR stingar.env
# Then fill every CHANGEME. stingar.env is gitignored — it holds live secrets
# (FLUENTD_KEY / API_KEY / PASSPHRASE / SALT) and must NEVER be committed.
#
# Generate the secrets:
#   FLUENTD_KEY / API_KEY :  openssl rand -base64 24 | tr -d '/+=' | head -c 32
#   PASSPHRASE / SALT     :  openssl rand -base64 24 | tr -d '/+=' | head -c 32
# FLUENTD_KEY MUST match the value every sensor's stingar-hp.env carries, or the
# central fluentd rejects their events.

# --- Identity / hostnames ----------------------------------------------------
# Public hostname the web UI + syslog advertise (this server's FQDN).
UI_HOSTNAME=CHANGEME.example.com
SYSLOG_HOSTNAME=CHANGEME.example.com
# Hostname sensors forward to (usually this same server; see sensor env).
FLUENTD_REMOTE_HOST=CHANGEME.example.com
INSTITUTION_NAME=UNIVERSITY
TAGS=network:local,type:dmz

# --- STINGAR API / crypto (SECRETS) ------------------------------------------
API_HOST=http://stingarapi:8000/
STINGAR_SERVICE_URL=http://stingarapi:8000/api/v2
API_KEY=CHANGEME
PASSPHRASE=CHANGEME
SALT=CHANGEME
DEFAULT_ROWS_PER_PAGE=1000
USER_DOC_URL=/docs
THEME_LIGHT_BASE_COLOR=white

# --- Fluentd / Fluent Bit transport ------------------------------------------
# FLUENTD_KEY is the shared secret between this server and every sensor.
FLUENTD_KEY=CHANGEME
FLUENTD_APP=stingar
FLUENTD_HOST=fluentd
FLUENTD_PORT=24224
FLUENTD_LOCAL_PORT=24225
FLUENTBIT_APP=stingar
FLUENTBIT_HOST=fluentbit
FLUENTBIT_HOSTNAME=flb.local
FLUENTBIT_PORT=24284

# --- Remote store / CIF / syslog outputs (optional) --------------------------
# 4warned remote store: set ENABLED=true and paste the issued API key.
REMOTE_STORE_ENABLED=false
REMOTE_STORE_BASE_URL=https://store.4warned.io
REMOTE_STORE_API_KEY=CHANGEME
# CIF threat-intel out (legacy STINGAR path; the c2-engine M4 feed replaces it).
CIF_ENABLED=false
CIF_HOST=
CIF_TOKEN=
CIF_PROVIDER=
CIF_GROUP=everyone
CIF_TAGS=honeypots
CIF_CONFIDENCE=9
FILE_ENABLED=false
SYSLOG_ENABLED=false
SYSLOG_HOST=
SYSLOG_PORT=514
SYSLOG_PROTOCOL=udp
SYSLOG_SEVERITY=info

# --- Honeypot lifecycle / updates --------------------------------------------
CLEANUP_AFTER_HOURS=24
CLEANUP_OLD_IMAGES=false
HONEYPOT_HEALTHCHECK_INTERVAL=PT01h0m0s
HONEYPOT_HEALTHCHECK_TIMEOUT=60s
IDS_RULES_AUTO_UPDATE_ENABLED=false
IDS_RULES_AUTO_UPDATE_INTERVAL=300
IDS_RULES_CACHE_PATH=/var/lib/stingar/ids-rules/stingar-honeypot.rules
IDS_RULES_FEED_DATE_RANGE=30d
UPDATE_SERVICE_ENABLED=true
UPDATE_MODE=manual
UPDATE_CHECK_INTERVAL=10800
UPDATE_WINDOW_START=00:00
UPDATE_WINDOW_END=03:00
DOCKER_USERNAME=
DOCKER_PASSWORD=
DOCKER_REPOSITORY=

# =============================================================================
# c2-engine optional intel enrichment (read by the c2reason service).
# All OFF by default; leave blank to disable. The reason layer never lets intel
# change a C2's stage — these only add stage_signals / annotations.
# =============================================================================

# M3 — VirusTotal. Set a key to enrich served-file hashes. With a PUBLIC key
# keep C2E_VT_MAX_PER_RUN <= 4 (== VT's 4 req/min; the job sleeps 5m per run).
VT_API_KEY=
C2E_VT_MAX_PER_RUN=4
C2E_VT_MIN_MALICIOUS=1

# M6 — abuse.ch feeds (ThreatFox / URLhaus / Feodo). Get a free Auth-Key at
# https://auth.abuse.ch/ . Feeds bulk-download on a TTL into the c2-intel cache.
ABUSECH_AUTH_KEY=
C2E_INTEL_TTL_HOURS=12
C2E_INTEL_FEEDS=threatfox,urlhaus,feodo
